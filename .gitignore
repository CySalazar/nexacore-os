# =============================================================================
# NexaCore OS — workspace .gitignore
# =============================================================================

# --- Rust build artifacts ---------------------------------------------------
/target/
**/target/
*.rs.bk
*.pdb

# --- Build / image outputs --------------------------------------------------
/dist/
/disk-image/target/
*.iso
*.img
*.img.raw
*.efi.tmp

# --- Agent instruction file: local only, never uploaded ---------------------
CLAUDE.md

# --- Local agent / editor state ---------------------------------------------
/.claude/
.vscode/
.idea/

# --- macOS / Windows filesystem turds ---------------------------------------
.DS_Store
._*
Thumbs.db
desktop.ini

# --- Secrets (never commit) -------------------------------------------------
*.pem
*.key
!keys/*.pub
!keys/*.pub.pem
/keys/*private*
.env
.env.*

# --- Logs / scratch ----------------------------------------------------------
*.log
/tmp/
*.tmp
/.playwright-mcp/

# --- Local dev screenshots / captures at repo root --------------------------
/nav-dropdown-live.png

# mdBook end-user guide rendered output (WS14-04)
docs/user/book/

# --- rustdoc render output (regenerated by `cargo doc`) ---------------------
/doc/

# --- internal working docs (not part of the public repo) --------------------
/plan.md
/plan.md.bak
/progress-omni.md
/todo.md
/todo-desktop.md
